[Unit]
Description=4y-ui Service
After=network.target
Wants=network.target

[Service]
EnvironmentFile=-/etc/default/4y-ui
Environment="XRAY_VMESS_AEAD_FORCED=false"
Type=simple
WorkingDirectory=/usr/local/4y-ui/
ExecStart=/usr/local/4y-ui/4y-ui
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
