[Unit]
Description=4y-ui Service
After=network.target
Wants=network.target

[Service]
EnvironmentFile=-/etc/conf.d/4y-ui
Environment="XRAY_VMESS_AEAD_FORCED=false"
Type=simple
WorkingDirectory=/usr/lib/4y-ui/
ExecStart=/usr/lib/4y-ui/4y-ui
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
